{
	"name": "grab-tools",
	"version": "0.25.0",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"host": "vite --host",
		"test": "vitest run",
		"typecheck": "vue-tsc --noEmit",
		"lint": "eslint . --fix",
		"lint:ci": "eslint .",
		"format": "prettier --write src/",
		"format:ci": "prettier --check src/",
		"launch": "open https://localhost:5173/ && npm run dev",
		"check": "npm run typecheck && npm run lint && npm run format",
		"tauri": "tauri",
		"proto": "npx pbts -i src/assets/proto/proto.proto -o src/generated/proto.ts && echo 'You will have to manually clean up the file as it may have errors'",
		"helpers": "jiti scripts/generate-helpers.ts && npx prettier --write src/generated/helpers.ts",
		"nodes": "jiti scripts/generate-node-helpers.ts && npx prettier --write src/generated/nodes.ts"
	},
	"dependencies": {
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/legacy-modes": "^6.5.3",
		"@codemirror/lint": "^6.9.7",
		"@replit/codemirror-vim": "^6.3.0",
		"@sentry/vue": "^10.59.0",
		"@tonejs/midi": "^2.0.28",
		"codemirror": "^6.0.2",
		"jsfft": "^0.0.4",
		"jsfxr": "^1.4.1",
		"pako": "^2.2.0",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"protobufjs": "^8.6.4",
		"py-ast": "^1.9.0",
		"three": "^0.159.0",
		"vue": "^3.5.38",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tauri-apps/cli": "^2.11.3",
		"@types/node": "^26.0.0",
		"@types/three": "^0.181.0",
		"@vitejs/plugin-vue": "^6.0.7",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.9.2",
		"globals": "^17.7.0",
		"jiti": "^2.7.0",
		"postcss-nesting": "^14.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.0.16",
		"vite-plugin-mkcert": "^2.1.0",
		"vitest": "^4.1.9",
		"vue-eslint-parser": "^10.4.1",
		"vue-tsc": "^3.3.5"
	}
}
